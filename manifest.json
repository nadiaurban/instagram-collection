{
  "manifest_version": 2,
  "name": "Instagram Collector",
  "version": "1.0",
  "description": "Captures Instagram posts, reels, and comments as you browse. Exports clean NDJSON for research pipelines.",
  "homepage_url": "https://github.com/nadiaurban/instagram-collection",

  "browser_specific_settings": {
    "gecko": {
      "id": "instagram-collector@nadiaurban",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "downloads",
    "*://*.instagram.com/*"
  ],

  "background": {
    "scripts": ["capture-instagram.js", "background.js"]
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Instagram Collector"
  }
}
